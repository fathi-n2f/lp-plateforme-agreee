<style id='core-block-supports-inline-css'>
.wp-elements-7550087f14d2e87b99eda8c2da60a45f a:where(:not(.wp-element-button)){color:var(--wp--preset--color--primary);}.wp-elements-57d7611e9f7b02e7d5b6cb6ec2c17ddd a:where(:not(.wp-element-button)){color:var(--wp--preset--color--primary);}.wp-elements-81fa042ee2a18bc54d3562167128f527 a:where(:not(.wp-element-button)){color:var(--wp--preset--color--primary);}
